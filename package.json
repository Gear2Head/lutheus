{
  "name": "lutheus-cezarapor",
  "version": "2.1.0",
  "private": true,
  "description": "Lutheus CezaRapor - Moderation Analysis System",
  "workspaces": [
    "apps/*",
    "packages/*",
    "src/dashboard-v2"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:all --prefix src/dashboard-v2 && next build && npm run build:bot",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint -c eslintrc.cjs --no-error-on-unmatched-pattern \"src/**/*.{js,ts}\" \"apps/**/*.ts\" \"packages/**/*.ts\" \"tests/**/*.{js,ts}\"",
    "check": "npm run lint && npm run test",
    "env:check": "node scripts/check-env.cjs",
    "test": "jest --runInBand --passWithNoTests",
    "test:unit": "jest --runInBand --testPathPattern=tests/unit",
    "dev:ext": "echo Extension uses MV3 source files directly; no webpack config is present.",
    "dev:api": "npm run dev --workspace=apps/backend",
    "dev:bot": "npm run dev --workspace=apps/discord-bot",
    "build:bot": "npm run build --workspace=apps/discord-bot",
    "start:bot": "npm run build --workspace=apps/discord-bot && npm run start --workspace=apps/discord-bot"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.4.7",
    "google-auth-library": "^10.6.2",
    "lucide-react": "^0.475.0",
    "next": "^15.1.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.0.1",
    "ws": "^8.21.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  }
}
