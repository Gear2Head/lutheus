рџ§  Backend вЂ“ Secure Bootstrap (NestJS)
// apps/backend/src/main.ts
import { NestFactory } from "@nestjs/core";
import helmet from "helmet";
import rateLimit from "express-rate-limit";
import { AppModule } from "./app.module";

async function bootstrap() {
  const app = await NestFactory.create(AppModule, { bufferLogs: true });

  app.use(helmet());
  app.enableCors({ origin: false });
  app.use(rateLimit({ windowMs: 60_000, max: 120 }));
  app.getHttpAdapter().getInstance().disable("x-powered-by");

  await app.listen(3000);
}
bootstrap();
рџ¤– Discord Bot вЂ“ Command Skeleton (RBAC + Signed Requests)
// apps/discord-bot/src/commands/scan.ts
import { SlashCommandBuilder } from "discord.js";
import { signedRequest } from "../security/hmac";

export const ScanCommand = {
  data: new SlashCommandBuilder()
    .setName("scan")
    .setDescription("Trigger a moderation scan"),

  async execute(interaction) {
    const res = await signedRequest("/scans/start", { serverId: interaction.guildId });
    await interaction.reply({ content: `Scan started: ${res.id}`, ephemeral: true });
  }
};
рџ§© Extension вЂ“ Secure Messaging Bridge
// apps/extension/src/background/service_worker.ts
chrome.runtime.onMessage.addListener(async (msg, sender, sendResponse) => {
  if (msg.type === "START_SCAN") {
    const res = await fetch(`${process.env.API_BASE_URL}/scans/start`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-Signature": await signPayload(msg.payload)
      },
      body: JSON.stringify(msg.payload),
    });
    sendResponse(await res.json());
  }
  return true;
});
