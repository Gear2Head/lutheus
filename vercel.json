{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/admin/:route",
      "destination": "/api/admin/[route]?route=:route"
    },
    {
      "source": "/api/scan/sapphire/:action",
      "destination": "/api/scan/sapphire/[action]?action=:action"
    },
    {
      "source": "/public/:path*",
      "destination": "/:path*"
    }
  ]
}
